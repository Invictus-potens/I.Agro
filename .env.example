# Conexão Postgres
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# Chaves API
WEATHER_API_KEY=
GEMINI_API_KEY=
PORT=8005

# Auth JWT — troque por uma string longa e aleatória em produção
